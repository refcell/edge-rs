// test_impl.edge — Execution tests for impl blocks and method calls
//
// Tests inherent impl methods, method call syntax (obj.method()),
// and qualified method calls (Type::method()).

type Point = {
    x: u256,
    y: u256,
};

impl Point {
    fn sum(self) -> (u256) {
        return self.x + self.y;
    }

    fn scale(self, factor: u256) -> (u256) {
        return self.x * factor + self.y * factor;
    }

    fn x_val(self) -> (u256) {
        return self.x;
    }
}

type Counter = {
    value: u256,
};

impl Counter {
    fn get(self) -> (u256) {
        return self.value;
    }

    fn add(self, n: u256) -> (u256) {
        return self.value + n;
    }
}

contract TestImpl {
    // Test method call: point.sum()
    pub fn test_point_sum() -> (u256) {
        let p: Point = Point { x: 10, y: 20 };
        return p.sum();
    }

    // Test method call with args: point.scale(3)
    pub fn test_point_scale() -> (u256) {
        let p: Point = Point { x: 5, y: 7 };
        return p.scale(3);
    }

    // Test method call: point.x_val()
    pub fn test_point_x() -> (u256) {
        let p: Point = Point { x: 42, y: 99 };
        return p.x_val();
    }

    // Test counter.get()
    pub fn test_counter_get() -> (u256) {
        let c: Counter = Counter { value: 100 };
        return c.get();
    }

    // Test counter.add(n)
    pub fn test_counter_add() -> (u256) {
        let c: Counter = Counter { value: 100 };
        return c.add(50);
    }
}
