// test_constants.edge — constant values and literal types
// Note: const inside contract body is not yet supported,
// so we test inline constants and literals in functions.

abi ITestConstants {
    fn get_decimal() -> (u256);
    fn get_hex() -> (u256);
    fn get_large_decimal() -> (u256);
    fn literal_arithmetic() -> (u256);
    fn hex_arithmetic() -> (u256);
    fn mixed_literals(x: u256) -> (u256);
}

contract TestConstants {

    // Test: decimal literal
    pub fn get_decimal() -> (u256) {
        return 42;
    }

    // Test: hex literal
    pub fn get_hex() -> (u256) {
        return 0xff;
    }

    // Test: large decimal literal
    pub fn get_large_decimal() -> (u256) {
        return 1000000;
    }

    // Test: arithmetic with literals
    pub fn literal_arithmetic() -> (u256) {
        return 100 + 200 * 3;
    }

    // Test: hex in arithmetic
    pub fn hex_arithmetic() -> (u256) {
        return 0x10 + 0x20;
    }

    // Test: literals mixed with args
    pub fn mixed_literals(x: u256) -> (u256) {
        return x * 1000 + 42;
    }
}
