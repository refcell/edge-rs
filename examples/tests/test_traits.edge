// test_traits.edge — Execution tests for trait declarations and implementations
//
// Tests trait method dispatch via:
// - Qualified calls: Trait::method(val)
// - Method-call syntax: val.method()
// - Operator overloading via std::ops traits

use std::ops::Add;
use std::ops::Eq;

type Wrapper = {
    val: u256,
};

trait Doubler {
    fn double(self) -> (u256);
}

trait Tripler {
    fn triple(self) -> (u256);
}

impl Wrapper: Doubler {
    fn double(self) -> (u256) {
        return self.val * 2;
    }
}

impl Wrapper: Tripler {
    fn triple(self) -> (u256) {
        return self.val * 3;
    }
}

impl Wrapper: Add {
    fn add(self, other: Self) -> (Self) {
        return Wrapper { val: self.val + other.val };
    }
}

impl Wrapper: Eq {
    fn eq(self, other: Self) -> (bool) {
        return self.val == other.val;
    }
}

contract TestTraits {
    // Qualified call: Doubler::double(w)
    pub fn test_double() -> (u256) {
        let w: Wrapper = Wrapper { val: 21 };
        return Doubler::double(w);
    }

    // Method-call syntax: w.double()
    pub fn test_double_method() -> (u256) {
        let w: Wrapper = Wrapper { val: 21 };
        return w.double();
    }

    // Qualified call: Tripler::triple(w)
    pub fn test_triple() -> (u256) {
        let w: Wrapper = Wrapper { val: 10 };
        return Tripler::triple(w);
    }

    // Method-call syntax: w.triple()
    pub fn test_triple_method() -> (u256) {
        let w: Wrapper = Wrapper { val: 10 };
        return w.triple();
    }

    // Chaining trait calls via method syntax
    pub fn test_double_then_triple() -> (u256) {
        let w: Wrapper = Wrapper { val: 5 };
        let doubled: u256 = w.double();
        return doubled * 3;
    }

    // Operator overloading: + dispatches to Add::add
    pub fn test_add_overload() -> (u256) {
        let a: Wrapper = Wrapper { val: 10 };
        let b: Wrapper = Wrapper { val: 32 };
        let c: Wrapper = a + b;
        return c.val;
    }

    // Operator overloading: == dispatches to Eq::eq
    pub fn test_eq_overload() -> (u256) {
        let a: Wrapper = Wrapper { val: 42 };
        let b: Wrapper = Wrapper { val: 42 };
        if a == b {
            return 1;
        }
        return 0;
    }
}
