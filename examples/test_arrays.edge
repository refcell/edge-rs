// test_arrays.edge — Execution tests for array features
//
// A contract with public functions that exercise array instantiation,
// element access, iteration, and storage arrays.

contract TestArrays {
    let values: &s [u256; 5];

    pub fn element_access() -> (u256) {
        let arr: [u256; 3];
        arr = [10, 20, 30];
        return arr[1];
    }

    pub fn sum_array() -> (u256) {
        let arr: [u256; 4];
        arr = [10, 20, 30, 40];
        let total: u256;
        total = 0;
        for (let i: u256 = 0; i < 4; i = i + 1) {
            total = total + arr[i];
        }
        return total;
    }

    pub fn set(index: u256, value: u256) {
        values[index] = value;
    }

    pub fn get(index: u256) -> (u256) {
        return values[index];
    }

    pub fn slice_sum() -> (u256) {
        let arr: [u256; 5];
        arr = [10, 20, 30, 40, 50];
        let slice: [u256; 2];
        slice = arr[1:3];
        return slice[0] + slice[1];
    }
}
