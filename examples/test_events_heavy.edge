// test_events_heavy.edge — event emission stress testing

event NoIndexed(value: u256);
event OneIndexed(indexed key: u256, value: u256);
event TwoIndexed(indexed from: addr, indexed to: addr, amount: u256);
event ThreeIndexed(indexed a: u256, indexed b: u256, indexed c: u256);
event MultiField(indexed key: addr, val1: u256, val2: u256);

abi ITestEventsHeavy {
    fn emit_no_indexed(val: u256);
    fn emit_one_indexed(key: u256, val: u256);
    fn emit_two_indexed(from: addr, to: addr, amount: u256);
    fn emit_three_indexed(a: u256, b: u256, c: u256);
    fn emit_multi_field(key: addr, v1: u256, v2: u256);
    fn emit_multiple(a: u256, b: u256);
    fn get_marker() -> (u256);
}

contract TestEventsHeavy {
    let marker: &s u256;

    // LOG1: topic0 = event sig hash, data = value
    pub fn emit_no_indexed(val: u256) {
        emit NoIndexed(val);
        marker = 1;
    }

    // LOG2: topic0 = sig, topic1 = key, data = value
    pub fn emit_one_indexed(key: u256, val: u256) {
        emit OneIndexed(key, val);
        marker = 2;
    }

    // LOG3: topic0 = sig, topic1 = from, topic2 = to, data = amount
    pub fn emit_two_indexed(from: addr, to: addr, amount: u256) {
        emit TwoIndexed(from, to, amount);
        marker = 3;
    }

    // LOG4: topic0 = sig, topic1 = a, topic2 = b, topic3 = c
    pub fn emit_three_indexed(a: u256, b: u256, c: u256) {
        emit ThreeIndexed(a, b, c);
        marker = 4;
    }

    // LOG2 with multiple non-indexed data fields
    pub fn emit_multi_field(key: addr, v1: u256, v2: u256) {
        emit MultiField(key, v1, v2);
        marker = 5;
    }

    // Multiple emits in one function
    pub fn emit_multiple(a: u256, b: u256) {
        emit NoIndexed(a);
        emit NoIndexed(b);
        emit OneIndexed(a, b);
        marker = 6;
    }

    pub fn get_marker() -> (u256) {
        return marker;
    }
}
